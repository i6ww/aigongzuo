```import requests
import os
import base64

# API配置
url = "https://www.371181668.xyz/v1/chat/completions"
api_key = "sk-jEw5qmOeU6oRfrNED8NWxH8***********************"
model_name = "firefly-nano-banana-pro-1k-16x9"

# 本地参考图片路径
image_path = r"c:\Users\Administrator\Desktop\newapi test\参考图.png"

# 检查图片文件是否存在
if not os.path.exists(image_path):
    print("参考图片不存在，请检查路径是否正确")
    exit()

# 将图片转换为Base64编码
def image_to_base64(image_path):
    with open(image_path, "rb") as image_file:
        encoded_string = base64.b64encode(image_file.read()).decode('utf-8')
    return encoded_string

# 获取图片的MIME类型
def get_image_mime_type(image_path):
    ext = os.path.splitext(image_path)[1].lower()
    mime_types = {
        '.png': 'image/png',
        '.jpg': 'image/jpeg',
        '.jpeg': 'image/jpeg',
        '.gif': 'image/gif',
        '.webp': 'image/webp'
    }
    return mime_types.get(ext, 'image/jpeg')

# 转换图片为Base64
base64_image = image_to_base64(image_path)
mime_type = get_image_mime_type(image_path)
image_data_url = f"data:{mime_type};base64,{base64_image}"

# 请求参数
payload = {
    "model": model_name,
    "messages": [{
        "role": "user",
        "content": [
            {"type": "text", "text": "把参考图的背景换成喜庆的中国城"},
            {"type": "image_url", "image_url": {"url": image_data_url}}
        ]
    }]
}

# 请求头
headers = {
    "Authorization": f"Bearer {api_key}",
    "Content-Type": "application/json"
}

try:
    # 发送POST请求
    response = requests.post(url, headers=headers, json=payload)
    
    # 输出响应结果
    print("响应状态码:", response.status_code)
    print("响应内容:", response.text)
    
    # 如果是JSON响应，可以解析
    if response.headers.get("Content-Type") and "application/json" in response.headers.get("Content-Type"):
        response_json = response.json()
        print("解析后的响应:", response_json)
        
        # 处理响应中的图片
        if "choices" in response_json:
            for i, choice in enumerate(response_json["choices"]):
                if "message" in choice and "content" in choice["message"]:
                    content = choice["message"]["content"]
                    print(f"响应内容 {i}: {content}")
                    
                    # 从Markdown响应中提取图片URL
                    import re
                    image_urls = re.findall(r'\!\[.*?\]\((.*?)\)', content)
                    
                    for j, image_url in enumerate(image_urls):
                        print(f"图片URL {j}: {image_url}")
                        
                        # 下载图片
                        try:
                            image_response = requests.get(image_url)
                            if image_response.status_code == 200:
                                output_path = f"edited_image_{i}_{j}.png"
                                with open(output_path, "wb") as f:
                                    f.write(image_response.content)
                                print(f"编辑后的图片已保存到: {output_path}")
                        except Exception as e:
                            print(f"下载图片时出错: {str(e)}")
                        
except Exception as e:
    print("请求出错:", str(e))
```